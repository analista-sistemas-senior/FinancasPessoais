@using FinancasPessoais.Domain.Enums
@model FinancasPessoais.Web.ViewModels.InvestimentoHistoricoViewModel
@{
    ViewData["Title"] = "Atualizar histórico do investimento";
}
<div class="p-3 p-md-5">
    <form asp-action="Atualizacao" method="post" autocomplete="off">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="IDInvestimentoHistoricoCriptografado"/>
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-stretch align-items-md-center mb-3 gap-2">
            <h1 class="fs-3 text-secondary m-0"><i class="bi bi-pencil-square"></i> @ViewData["Title"]</h1>
            <div class="align-self-end align-self-md-center mt-2">
                <button type="submit" class="btn btn-primary fw-bold shadow-sm"><i class="bi bi-floppy-fill me-2"></i>Atualizar</button>
                <a class="btn btn-secondary fw-bold shadow-sm" asp-action="Index"><i class="bi bi-arrow-left-square me-2"></i>Voltar</a>
            </div>
        </div>
        <hr/>
        <div class="mb-3">
            <label asp-for="IDInvestimento" class="form-label fw-semibold text-secondary mb-1"></label>
            <select asp-for="IDInvestimento" class="form-select border-2 shadow-sm" asp-items="@((SelectList)ViewData["Investimentos"]!)" required></select>
            <span asp-validation-for="IDInvestimento" class="text-danger small fw-semibold"></span>
        </div>
        <div class="mb-3">
            <label asp-for="DTInvestimentoHistorico" class="form-label fw-semibold text-secondary mb-1"></label>
            <input asp-for="DTInvestimentoHistorico" type="datetime-local" class="form-control border-2 shadow-sm" placeholder="Insira data do histórico do investimento" required />
            <span asp-validation-for="DTInvestimentoHistorico" class="text-danger small fw-semibold"></span>
        </div>
        <div class="mb-3">
            <label asp-for="VLInvestimentoHistorico" class="form-label fw-semibold text-secondary mb-1"></label>
            <input asp-for="VLInvestimentoHistorico" type="number" class="form-control border-2 shadow-sm" placeholder="Insira valor do histórico do investimento" required data-val-number="O campo deve ter um número válido" />
            <span asp-validation-for="VLInvestimentoHistorico" class="text-danger small fw-semibold"></span>
        </div>
        <div class="mb-3">
            <label asp-for="INInvestimentoHistorico" class="form-label fw-semibold text-secondary mb-1"></label>
            <select asp-for="INInvestimentoHistorico" class="form-select border-2 shadow-sm" asp-items="Html.GetEnumSelectList<TipoInvestimentoHistorico>()"></select>
            <span asp-validation-for="INInvestimentoHistorico" class="text-danger small fw-semibold"></span>
        </div>
    </form>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}