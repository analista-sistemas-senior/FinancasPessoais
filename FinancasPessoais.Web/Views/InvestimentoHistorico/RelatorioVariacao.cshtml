@model IEnumerable<FinancasPessoais.Web.ViewModels.Reports.RelatorioInvestimentoVariacaoViewModel>
@{
    ViewData["Title"] = "Variação dos investimentos";
}
<link rel="stylesheet" href="~/lib/datatables.net-bs5/dataTables.bootstrap5.min.css"/>
<div class="p-3 p-md-5">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-stretch align-items-md-center mb-3 gap-2">
        <h1 class="fs-3 text-secondary m-0"><i class="bi bi-percent"></i> @ViewData["Title"]</h1>
        <div class="d-flex flex-row align-self-end align-self-md-center align-items-center">
            <i class="bi bi-question-circle fs-4 me-3 mb-0 cursor-pointer" title="Ajuda" data-bs-toggle="modal" data-bs-target="#modalAjuda"></i>
            <a class="btn btn-secondary fw-bold shadow-sm" asp-action="Index"><i class="bi bi-arrow-left-square me-2"></i>Voltar</a>
        </div>
    </div>
    <hr/>
    <div class="table-responsive">
        <table id="tabelaInvestimentoHistoricoVariacao" class="table align-middle m-0">
            <thead class="table-light">
                <tr>
                    <th scope="col" class="text-secondary small fw-bold text-uppercase ps-3">@Html.DisplayNameFor(model => model.NMInvestimento)</th>
                    <th scope="col" class="text-secondary small fw-bold text-uppercase ps-3">@Html.DisplayNameFor(model => model.DTInvestimento)</th>
                    <th scope="col" class="text-secondary small fw-bold text-uppercase ps-3">@Html.DisplayNameFor(model => model.DTVencimento)</th>
                    <th scope="col" class="text-secondary small fw-bold text-uppercase ps-3">@Html.DisplayNameFor(model => model.PCTaxaRentabilidade)</th>
                    <th scope="col" class="text-secondary small fw-bold text-uppercase ps-3">@Html.DisplayNameFor(model => model.VLSaldo)</th>
                    <th scope="col" class="text-secondary small fw-bold text-uppercase ps-3">@Html.DisplayNameFor(model => model.FLLiquidado)</th>
                    <th scope="col" class="text-secondary small fw-bold text-uppercase ps-3">@Html.DisplayNameFor(model => model.VLInvestimentoVariacao)</th>
                    <th scope="col" class="text-secondary small fw-bold text-uppercase ps-3">@Html.DisplayNameFor(model => model.PCInvestimentoVariacao)</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var investimento in Model)
                {
                    <tr>
                        <td>@investimento.NMInvestimento</td>
                        <td data-order="@investimento.DTInvestimento.ToString("yyyyMMddHHmmss")">@investimento.DTInvestimento.ToString("dd/MM/yyyy HH:mm")</td>
                        @if (investimento.DTVencimento.HasValue)
                        {
                            <td data-order="@investimento.DTVencimento.Value.ToString("yyyyMMddHHmmss")">@investimento.DTVencimento.Value.ToString("dd/MM/yyyy")</td>
                        }
                        else
                        {
                            <td>-</td>
                        }
                        <td>
                            @investimento.PCTaxaRentabilidade %
                            @Html.DisplayFor(modelItem => investimento.INTaxaPeriodicidade)
                        </td>
                        <td>
                            @if (investimento.VLSaldo > 0)
                            {
                                <span class="verde fw-semibold">@investimento.VLSaldo.ToString("C", new System.Globalization.CultureInfo("pt-BR"))</span>
                            }
                            @if (investimento.VLSaldo == 0)
                            {
                                <span class="cinza fw-semibold">@investimento.VLSaldo.ToString("C", new System.Globalization.CultureInfo("pt-BR"))</span>
                            }
                            @if (investimento.VLSaldo < 0)
                            {
                                <span class="vermelho fw-semibold">@investimento.VLSaldo.ToString("C", new System.Globalization.CultureInfo("pt-BR"))</span>
                            }
                        </td>
                        <td>
                            @if (investimento.FLLiquidado == true)
                            {
                                <span>Sim</span>
                            }
                            else
                            {
                                <span>Não</span>
                            }
                        </td>
                        <td>@investimento.VLInvestimentoVariacao.ToString("C", new System.Globalization.CultureInfo("pt-BR"))</td>
                        <td>@investimento.PCInvestimentoVariacao.ToString("F2") %</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<div class="modal fade" id="modalAjuda" tabindex="-1" aria-labelledby="modalAjudaLabel">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-lg border-0">
            <div class="modal-header bg-opacity-10 bg-black border-bottom-0 py-3">
                <h5 class="modal-title fw-bold d-flex align-items-center" id="modalAjudaLabel">
                    <i class="bi bi-info-circle me-2"></i> Entendendo este relatório
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body py-4">
                <p class="text-secondary mb-3">
                    Este relatório mostra a variação do valor atual do investimento em relação ao último saldo registrado dele.
                </p>
            </div>
            <div class="modal-footer border-top-0 pt-0">
                <button type="button" class="btn btn-secondary btn-sm fw-bold px-3" data-bs-dismiss="modal">Fechar</button>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/lib/datatables.net/dataTables.min.js"></script>
    <script src="~/lib/datatables.net-bs5/dataTables.bootstrap5.min.js"></script>
    <script>
        $(document).ready(function () {

            new DataTable('#tabelaInvestimentoHistoricoVariacao', {
                language: { url: '/lib/datatables-plugins/i18n/pt-BR.json' },
                pageLength: 50,
                columnDefs: [
                    { type: 'date-eu', targets: [1,2] }
                ],
                order: [[1, 'desc']]
            });

        });
    </script>
}