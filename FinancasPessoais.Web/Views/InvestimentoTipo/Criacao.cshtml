@using FinancasPessoais.Domain.Enums
@model FinancasPessoais.Web.ViewModels.InvestimentoTipoViewModel
@{
    ViewData["Title"] = "Criar novo tipo de investimento";
}
<div class="p-3 p-md-5">
    <form asp-action="Criacao" method="post" autocomplete="off">
        @Html.AntiForgeryToken()
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-stretch align-items-md-center mb-3 gap-2">
            <h1 class="fs-3 text-secondary m-0"><i class="bi bi-file-earmark-plus"></i> @ViewData["Title"]</h1>
            <div class="align-self-end align-self-md-center mt-2">
                <button type="submit" class="btn btn-primary fw-bold shadow-sm"><i class="bi bi-floppy-fill me-2"></i>Criar</button>
                <a class="btn btn-secondary fw-bold shadow-sm" asp-action="Index"><i class="bi bi-arrow-left-square me-2"></i>Voltar</a>
            </div>
        </div>
        <hr/>
        <div class="mb-3">
            <label asp-for="NMInvestimentoTipo" class="form-label fw-semibold text-secondary mb-1"></label>
            <input asp-for="NMInvestimentoTipo" class="form-control border-2 shadow-sm" placeholder="Insira nome do tipo de investimento" required autofocus/>
            <span asp-validation-for="NMInvestimentoTipo" class="text-danger small fw-semibold"></span>
        </div>
        <div class="mb-3">
            <label asp-for="SGInvestimentoTipo" class="form-label fw-semibold text-secondary mb-1"></label>
            <input asp-for="SGInvestimentoTipo" class="form-control border-2 shadow-sm" placeholder="Insira sigla do tipo de investimento" required/>
            <span asp-validation-for="SGInvestimentoTipo" class="text-danger small fw-semibold"></span>
        </div>
        <div class="mb-3">
            <label asp-for="INTipoRentabilidade" class="form-label fw-semibold text-secondary mb-1"></label>
            <select asp-for="INTipoRentabilidade" class="form-select border-2 shadow-sm" asp-items="Html.GetEnumSelectList<TipoRentabilidade>()" required id="INTipoRentabilidade"></select>
            <span asp-validation-for="INTipoRentabilidade" class="text-danger small fw-semibold"></span>
        </div>
        <div class="mb-3">
            <label asp-for="IDIndexador" class="form-label fw-semibold text-secondary mb-1"></label>
            <select asp-for="IDIndexador" class="form-select border-2 shadow-sm" asp-items="@((SelectList)ViewData["Indexadores"]!)" required id="IDIndexador"></select>
            <span asp-validation-for="IDIndexador" class="text-danger small fw-semibold"></span>
        </div>
    </form>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
    <script>
        $(document).ready(function () {

            let valorNA = "@((int)TipoRentabilidade.NA)";
            let valorPre = "@((int)TipoRentabilidade.PreFixado)";

            $('#INTipoRentabilidade').on('change', function () {

                if ($(this).val() == valorNA || $(this).val() == valorPre) $("#IDIndexador").prop("disabled", true);
                else $("#IDIndexador").prop("disabled", false);

            });

            let rentabilidade = $("#INTipoRentabilidade").val();
            if (rentabilidade == valorNA || rentabilidade == valorPre) $("#IDIndexador").prop("disabled", true);

        });
    </script>
}